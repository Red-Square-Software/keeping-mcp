{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "noEmit": true,
    "outDir": "dist",
    "declaration": false,
    "lib": ["ES2023"]
  },
  "include": ["bin/**/*", "src/**/*", "test/**/*", "*.ts"],
  "exclude": ["dist", "node_modules"]
}
